# mike-telegram-bot — environment.
# The bot reads these as environment variables. Either export them in your shell,
# or load this file, e.g.:  set -a; source .env; set +a   (after copying to .env)

# REQUIRED. Your bot token from @BotFather (https://t.me/BotFather → /newbot).
# Keep it secret — never commit a real token.
TELEGRAM_BOT_TOKEN=

# Optional. Backend base URL (default shown).
MIKE_API_URL=http://localhost:3001

# Optional. Static fallback session token / bypass. Normally you authenticate
# in-chat with /login <PIN> instead, so leave this empty.
MIKE_SESSION_TOKEN=

# Optional. Model id to pass through; empty → backend default.
MIKE_MODEL=
