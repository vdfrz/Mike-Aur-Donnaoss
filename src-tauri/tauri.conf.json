{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mike aur Donna",
  "version": "0.1.0",
  "identifier": "com.mikeaurdonna.app",
  "build": {
    "frontendDist": "../frontend/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm --prefix ./frontend run dev",
    "beforeBuildCommand": "npm --prefix ./frontend run build:tauri"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Mike aur Donna",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "pdfium/*",
      "pandoc/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}