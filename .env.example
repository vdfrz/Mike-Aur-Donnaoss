# MikeRust — environment variables

# SQLite database file path. Leave this UNSET to use the default
# (~/mikerust-data/mike.db, outside the project tree, created automatically).
# A *relative* path (e.g. sqlite://mike.db) resolves against the process
# working directory, so launching from a different folder gives you a fresh
# empty DB every time. Only override with an ABSOLUTE path:
# DATABASE_URL=sqlite:///absolute/path/to/mike.db

# Sovereign auth — generate with: openssl rand -base64 48
JWT_SECRET=your-random-secret-min-32-chars

# Storage — local filesystem (default) or S3/R2 (feature: s3-storage)
STORAGE_PATH=./data/storage
# R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=mike

# PDF extraction — pdfium DLL bundled in libs/pdfium/
# (no env var needed; discovered automatically next to executable)

# Local / self-hosted LLM via OpenAI-compatible endpoint (vLLM, Infomaniak, etc.)
VLLM_BASE_URL=
VLLM_API_KEY=
# Recommended for Ollama: qwen2.5:3b (runs on 8GB RAM, good instruction-following)
# Pull with: ollama pull qwen2.5:3b
VLLM_MAIN_MODEL=
VLLM_LIGHT_MODEL=

# Cloud LLM providers (optional — only needed if using Claude/Gemini)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# DeepSeek — recommended cloud provider (OpenAI-compatible API at api.deepseek.com).
# Used as the env fallback; you can also paste the key in-app under Account → Models.
DEEPSEEK_API_KEY=

# Indian Kanoon — Indian case-law search (optional; can also be set in-app).
IK_API_KEY=

# Donna review endpoint — cloud LLM for WhatsApp document review
DONNA_MODEL=

# MCP client — JSON array of server configs (optional)
# [{"name":"local-docs","url":"http://localhost:8080/mcp"}]
MCP_SERVERS=

# Server
PORT=3001
API_BASE_URL=http://localhost:3001
RUST_LOG=mike=debug,tower_http=info
