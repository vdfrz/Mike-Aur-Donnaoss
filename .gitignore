# ─── Rust / Tauri build artefacts ───────────────────────────────────
/target
/src-tauri/target
# Cargo registry caches that some IDE setups drop locally.
.cargo/
# Auto-generated by Tauri at build time (icons.rs, schemas/) — never
# hand-edited, regenerated on each `tauri dev|build`.
/src-tauri/gen
# Windows MSVC linker / debug residue that target/ usually contains
# but can leak elsewhere (e.g. when builds error out mid-link).
*.pdb
*.exp
*.lib
*.idb
# Rust coverage / profiling output.
*.profraw
coverage/

# ─── Frontend build / cache ─────────────────────────────────────────
/frontend/node_modules
/frontend/.next
/frontend/out
/frontend/dist
/frontend/build
/frontend/.turbo
/frontend/.swc
/frontend/.parcel-cache
/frontend/.cache
/frontend/.eslintcache
# TypeScript incremental build cache — wherever next/tsc drops it.
**/tsconfig.tsbuildinfo
*.tsbuildinfo

# ─── AI model + downloaded data ─────────────────────────────────────
# multilingual-e5-base ONNX weights (~1.1 GB) and tokenizer/configs.
# `ensure_fastembed_cache_dir()` pins these to %USERPROFILE%/mikerust-data
# but legacy / dev runs may leave them in either of these project paths.
.fastembed_cache/
mikerust-data/
# Generic catch-all for AI/ML caches that tools may drop in-repo.
.cache/
.huggingface/
.hf_cache/
**/huggingface_hub/
models/
*.onnx
*.safetensors
*.gguf
*.bin
*.pt
*.pth
# Compiled tokenizer files that fastembed downloads alongside the model.
tokenizer.json
spiece.model
sentencepiece.bpe.model

# ─── Application data ────────────────────────────────────────────────
# SQLite + storage tree (chats, indexed docs, FTS5 italian-corpus,
# EUR-Lex synced text, chat-attached docs cache, etc.).
data/
*.db
*.db-wal
*.db-shm
# Italian-legal-corpus parquet shards if the importer was set to keep
# them on disk for a future refresh (it doesn't today, but be safe).
/data_corpora/
italian-legal-*.parquet

# ─── pdfium DLL ─────────────────────────────────────────────────────
# Prebuilt platform-specific binary; README documents how to fetch.
libs/pdfium/
src-tauri/libs/pdfium/
# Setup archives downloaded from bblanchon/pdfium-binaries.
pdfium-*.tgz
pdfium-*.zip

# ─── Secrets ────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
**/.env.local
**/.env.*.local

# ─── Editor / OS ─────────────────────────────────────────────────────
.claude/
.vscode/
.idea/
.history/
*.swp
*.swo
*.bak
*.tmp
*.orig
*.rej
*.log
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini
ehthumbs.db

# ─── Ad-hoc planning notes — docs/ is the source of truth ───────────
PLAN.md
TODO.md

# Upstream Mike reference material (third-party docs from
# willchen96/mike + Semplifica adaptation notes) — kept on disk for
# author convenience but NOT shipped in this repo: those docs talk
# about a different stack and a different toolchain than MikeRust.
docs/mike-upstream/

# Training data (JSONL files with extracted legal texts)
training/*.jsonl

# WhatsApp web cache
.wwebjs_cache/

# Secrets & DB
mike.db
.env
.env.local

# Build artifacts
target/
.next/
frontend/.next/
frontend/node_modules/
graphify-out/

# Personal DB backups (never ship)
*.db.empty-backup
mike.db.empty-backup

# WhatsApp session
.wwebjs_auth/

# macOS
.DS_Store
